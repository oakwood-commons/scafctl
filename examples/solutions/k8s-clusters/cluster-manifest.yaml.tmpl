# Kubernetes Cluster Manifest
# Cluster: {{ .name }}
# Region: {{ .region }}
# Generated by scafctl
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ .name }}
  labels:
    cluster: {{ .name }}
    region: {{ .region }}
    environment: {{ .environment }}
    tier: {{ .tier }}
    owner: {{ .owner }}
    managed-by: scafctl
  annotations:
    kubernetes.io/description: "{{ .name }} cluster in {{ .region }} ({{ .environment }})"
    cluster.example.com/version: "{{ .version }}"
    cluster.example.com/cidr: "{{ .cidr }}"
    cluster.example.com/node-count: "{{ .nodeCount }}"
---
apiVersion: v1
kind: ResourceQuota
metadata:
  name: {{ .name }}-quota
  namespace: {{ .name }}
  labels:
    cluster: {{ .name }}
spec:
  hard:
{{- if eq .tier "production" }}
    requests.cpu: "64"
    requests.memory: 128Gi
    limits.cpu: "128"
    limits.memory: 256Gi
    pods: "{{ .maxPods }}"
    services: "200"
    persistentvolumeclaims: "100"
{{- else if eq .tier "staging" }}
    requests.cpu: "32"
    requests.memory: 64Gi
    limits.cpu: "64"
    limits.memory: 128Gi
    pods: "{{ .maxPods }}"
    services: "100"
    persistentvolumeclaims: "50"
{{- else }}
    requests.cpu: "16"
    requests.memory: 32Gi
    limits.cpu: "32"
    limits.memory: 64Gi
    pods: "{{ .maxPods }}"
    services: "50"
    persistentvolumeclaims: "25"
{{- end }}
---
apiVersion: v1
kind: LimitRange
metadata:
  name: {{ .name }}-limits
  namespace: {{ .name }}
spec:
  limits:
{{- if eq .tier "production" }}
    - type: Container
      default:
        cpu: "2"
        memory: 4Gi
      defaultRequest:
        cpu: "500m"
        memory: 1Gi
      max:
        cpu: "8"
        memory: 16Gi
    - type: Pod
      max:
        cpu: "16"
        memory: 32Gi
{{- else if eq .tier "staging" }}
    - type: Container
      default:
        cpu: "1"
        memory: 2Gi
      defaultRequest:
        cpu: "250m"
        memory: 512Mi
      max:
        cpu: "4"
        memory: 8Gi
    - type: Pod
      max:
        cpu: "8"
        memory: 16Gi
{{- else }}
    - type: Container
      default:
        cpu: "500m"
        memory: 1Gi
      defaultRequest:
        cpu: "100m"
        memory: 256Mi
      max:
        cpu: "2"
        memory: 4Gi
    - type: Pod
      max:
        cpu: "4"
        memory: 8Gi
{{- end }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .name }}-cluster-info
  namespace: {{ .name }}
data:
  cluster-name: {{ .name }}
  region: {{ .region }}
  environment: {{ .environment }}
  tier: {{ .tier }}
  kubernetes-version: "{{ .version }}"
  network-cidr: "{{ .cidr }}"
  node-count: "{{ .nodeCount }}"
  storage-class: {{ .storageClass }}
  owner: {{ .owner }}
{{- if eq .environment "prod" }}
  monitoring: "prometheus,datadog"
  alerting: "pagerduty"
  backup-enabled: "true"
  backup-schedule: "0 2 * * *"
{{- else if eq .environment "staging" }}
  monitoring: "prometheus"
  alerting: "slack"
  backup-enabled: "true"
  backup-schedule: "0 4 * * 0"
{{- else }}
  monitoring: "prometheus"
  alerting: "none"
  backup-enabled: "false"
{{- end }}
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ .name }}-default-deny
  namespace: {{ .name }}
spec:
  podSelector: {}
  policyTypes:
{{- if eq .tier "production" }}
    - Ingress
    - Egress
{{- else }}
    - Ingress
{{- end }}
