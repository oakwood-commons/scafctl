{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Auth Handlers",
  "description": "Schema for authentication handlers with display extensions",
  "type": "array",

  "x-kvx-icon": "🔐",
  "x-kvx-collectionTitle": "Auth Handlers",

  "x-kvx-list": {
    "titleField": "displayName",
    "subtitleField": "name",
    "subtitleMaxLines": 1,
    "badgeFields": ["flows"]
  },

  "x-kvx-detail": {
    "titleField": "displayName",
    "hiddenFields": [],
    "sections": [
      {
        "title": "",
        "fields": ["name", "displayName"],
        "layout": "inline"
      },
      {
        "title": "Supported Flows",
        "fields": ["flows"],
        "layout": "tags"
      },
      {
        "title": "Capabilities",
        "fields": ["capabilities"],
        "layout": "tags"
      }
    ]
  },

  "items": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "type": "string",
        "title": "Name",
        "description": "Handler identifier"
      },
      "displayName": {
        "type": "string",
        "title": "Display Name",
        "description": "Human-readable handler name"
      },
      "flows": {
        "type": "array",
        "items": { "type": "string" },
        "title": "Flows",
        "description": "Supported authentication flows"
      },
      "capabilities": {
        "type": "array",
        "items": { "type": "string" },
        "title": "Capabilities",
        "description": "Handler capabilities"
      }
    }
  }
}
