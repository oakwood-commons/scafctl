{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CLI Commands",
  "description": "Schema for CLI commands with display extensions",
  "type": "array",

  "x-kvx-icon": "⌘",
  "x-kvx-collectionTitle": "Commands",

  "x-kvx-list": {
    "titleField": "name",
    "subtitleField": "short",
    "subtitleMaxLines": 1,
    "badgeFields": ["group"]
  },

  "x-kvx-detail": {
    "titleField": "name",
    "hiddenFields": [],
    "sections": [
      {
        "title": "",
        "fields": ["name", "group"],
        "layout": "inline"
      },
      {
        "title": "Description",
        "fields": ["short"],
        "layout": "paragraph"
      },
      {
        "title": "Aliases",
        "fields": ["aliases"],
        "layout": "tags"
      },
      {
        "title": "Details",
        "fields": ["flagCount", "hasChildren", "deprecated"],
        "layout": "table"
      }
    ]
  },

  "items": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "type": "string",
        "title": "Name",
        "description": "Full command path"
      },
      "short": {
        "type": "string",
        "title": "Description",
        "description": "Short description"
      },
      "group": {
        "type": "string",
        "title": "Group",
        "description": "Command group"
      },
      "aliases": {
        "type": "array",
        "items": { "type": "string" },
        "title": "Aliases",
        "description": "Command aliases"
      },
      "flagCount": {
        "type": "integer",
        "title": "Flags",
        "description": "Number of flags"
      },
      "hasChildren": {
        "type": "boolean",
        "title": "Has Subcommands",
        "description": "Whether the command has subcommands"
      },
      "deprecated": {
        "type": "boolean",
        "title": "Deprecated",
        "description": "Whether the command is deprecated"
      }
    }
  }
}
